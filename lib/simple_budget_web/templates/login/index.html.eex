<script src="<%= Routes.static_path(@conn, "/js/login.js") %>"></script>

<div id="login" />

<script defer type="application/javascript" nonce="7q1w9Jiyp2Kf0xrGOGtdQGaW3IljYiEQXzOe/ftW9Q0=">
  var loginView = new Login({'ssoEnabled': '<%= Application.get_env(:simple_budget, :sso_enabled) %>'});
  loginView.render();
</script>
<script src="https://apis.google.com/js/platform.js?onload=init" async defer nonce="7q1w9Jiyp2Kf0xrGOGtdQGaW3IljYiEQXzOe/ftW9Q0="></script>
<script type="application/javascript" nonce="7q1w9Jiyp2Kf0xrGOGtdQGaW3IljYiEQXzOe/ftW9Q0=">
  function init() {
    gapi.load('auth2', function() {
      gapi.auth2.init({
        client_id: '<%= Application.get_env(:simple_budget, :google_client_id) %>',
        ux_mode: "redirect"
      }).then(function() {
        loginView.renderGoogleAuth();
      });
    });
  }
</script>